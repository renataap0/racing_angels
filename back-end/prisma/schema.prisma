generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  team
  driver
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(80)
  password  String   @db.VarChar(255)
  role      Role
  teamId    Int?     @map("team_id")
  driverId  Int?     @unique @map("driver_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team   Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  driver Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  orders Order[]

  @@map("users")
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(120)
  country     String?  @db.VarChar(80)
  principal   String?  @db.VarChar(120)
  foundedYear Int?     @map("founded_year")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users   User[]
  drivers Driver[]
  cars    Car[]
  races   Race[]

  @@map("teams")
}

model Driver {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(120)
  nationality String?  @db.VarChar(80)
  status      String   @default("Titular") @db.VarChar(40)
  number      Int?
  teamId      Int      @map("team_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User?
  cars            Car[]
  races           Race[]
  seasonRoundLaps SeasonRoundLap[]

  @@index([teamId])
  @@map("drivers")
}

model Car {
  id          Int      @id @default(autoincrement())
  model       String   @db.VarChar(120)
  code        String?  @db.VarChar(40)
  teamId      Int      @map("team_id")
  driverId    Int?     @map("driver_id")
  power       Int
  aero        Int
  reliability Int
  tireCare    Int      @map("tire_care")
  ers         Int
  topSpeed    Int      @map("top_speed")
  weight      Int
  packageName String?  @map("package_name") @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team            Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  driver          Driver?          @relation(fields: [driverId], references: [id], onDelete: SetNull)
  races           Race[]
  seasonRoundLaps SeasonRoundLap[]

  @@index([teamId])
  @@index([driverId])
  @@map("cars")
}

model Track {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(120)
  country     String   @db.VarChar(80)
  city        String   @db.VarChar(80)
  lengthKm    Float    @map("length_km")
  turns       Int
  sectors     Int
  recordLapMs Int      @map("record_lap_ms")
  grip        Int
  elevation   Int
  type        String   @db.VarChar(80)
  weather     String   @db.VarChar(80)
  abrasion    Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  races        Race[]
  seasonRounds SeasonRound[]

  @@map("tracks")
}

model Race {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(120)
  status    String    @default("Agendada") @db.VarChar(50)
  laps      Int
  bestLapMs Int       @map("best_lap_ms")
  lastLapMs Int       @map("last_lap_ms")
  raceDate  DateTime? @map("race_date")
  teamId    Int       @map("team_id")
  driverId  Int       @map("driver_id")
  trackId   Int       @map("track_id")
  carId     Int       @map("car_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  driver       Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  track        Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  car          Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  seasonRounds SeasonRound[]

  @@index([teamId])
  @@index([driverId])
  @@index([trackId])
  @@index([carId])
  @@map("races")
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  year      Int
  status    String   @default("Ativa") @db.VarChar(40)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rounds SeasonRound[]

  @@unique([name, year])
  @@map("seasons")
}

model SeasonRound {
  id          Int       @id @default(autoincrement())
  seasonId    Int       @map("season_id")
  raceId      Int?      @map("race_id")
  trackId     Int       @map("track_id")
  name        String    @db.VarChar(120)
  roundNumber Int       @map("round_number")
  scheduledAt DateTime? @map("scheduled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  season Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  race   Race?           @relation(fields: [raceId], references: [id], onDelete: SetNull)
  track  Track           @relation(fields: [trackId], references: [id], onDelete: Cascade)
  laps   SeasonRoundLap[]

  @@unique([seasonId, roundNumber])
  @@index([trackId])
  @@index([raceId])
  @@map("season_rounds")
}

model SeasonRoundLap {
  id            Int      @id @default(autoincrement())
  seasonRoundId Int      @map("season_round_id")
  driverId      Int      @map("driver_id")
  carId         Int?     @map("car_id")
  lapNumber     Int      @map("lap_number")
  lapTimeMs     Int      @map("lap_time_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  seasonRound SeasonRound @relation(fields: [seasonRoundId], references: [id], onDelete: Cascade)
  driver      Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  car         Car?        @relation(fields: [carId], references: [id], onDelete: SetNull)

  @@unique([seasonRoundId, driverId, lapNumber])
  @@index([driverId])
  @@index([carId])
  @@map("season_round_laps")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(120)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int
  imageUrl    String?  @map("image_url") @db.VarChar(255)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(40)
  userId        Int      @map("user_id")
  customerName  String   @map("customer_name") @db.VarChar(120)
  customerEmail String   @map("customer_email") @db.VarChar(120)
  customerZip   String   @map("customer_zip") @db.VarChar(20)
  paymentMethod String   @map("payment_method") @db.VarChar(40)
  subtotal      Decimal  @db.Decimal(10, 2)
  shipping      Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  status        String   @default("aprovado") @db.VarChar(40)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}
